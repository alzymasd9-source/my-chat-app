<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>شات اليمن العربي</title>
<style>
@font-face {
    font-family: Tajawal;
    src: url(https://fonts.gstatic.com/s/tajawal/v20/rcrwv9qY5bW70J8eXW7DbQ.woff2) format('woff2');
}
* { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Tajawal', Tahoma, sans-serif; }
body { background: #ededed; direction: rtl; }
.header { background-color: #0f414e; padding: 10px 20px; display: flex; justify-content: space-between; align-items: center; color: #fff; }
.logo { font-size: 28px; font-weight: bold; }
.main { min-height: 100vh; background: #00242e url(https://images.unsplash.com/photo-1557682250-33bd709cbe85?w=1920) no-repeat center/cover fixed; padding: 20px; }
.center { max-width: 800px; margin: 0 auto; }
.room-card { background: rgba(255,255,255,0.95); border-radius: 15px; overflow: hidden; margin-bottom: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.3); }
.room-header { background: linear-gradient(135deg, #0f414e, #195b86); color: #fff; padding: 20px; text-align: center; }
.login-box { padding: 30px; background: #f9f9f9; text-align: center; }
.form-group input { width: 100%; max-width: 300px; padding: 12px 15px; font-size: 18px; border: 2px solid #ddd; border-radius: 10px; text-align: center; margin-bottom: 15px; }
.gender-select { display: flex; justify-content: center; gap: 20px; margin: 20px 0; }
.gender-option { cursor: pointer; padding: 15px 25px; border: 2px solid #ddd; border-radius: 10px; }
.gender-option.selected { border-color: #0f414e; background: #e3f0f7; }
.btn { background: #0f414e; color: #fff; padding: 12px 30px; border: none; border-radius: 10px; font-size: 18px; cursor: pointer; }
.chat-container { display: none; background: rgba(255,255,255,0.98); border-radius: 15px; overflow: hidden; }
.chat-messages { height: 400px; overflow-y: auto; padding: 20px; background: #f9f9f9; }
.message { margin-bottom: 15px; padding: 12px 15px; border-radius: 15px; max-width: 80%; }
.message.mine { background: #e3f0f7; margin-right: auto; }
.message.other { background: #fff; margin-left: auto; }
.message-sender.male { color: #06f; font-weight: bold; }
.message-sender.female { color: #e13; font-weight: bold; }
.chat-input-area { padding: 15px; background: #fff; display: flex; gap: 10px; }
.chat-input { flex: 1; padding: 12px 15px; border: 2px solid #ddd; border-radius: 25px; font-size: 16px; }
.send-btn { background: #0f414e; color: #fff; border: none; padding: 12px 25px; border-radius: 25px; cursor: pointer; }
.system-message { text-align: center; color: #666; font-size: 14px; margin: 10px 0; }
.user-list { padding: 15px; border-bottom: 1px solid #ddd; }
.user-list li { list-style: none; padding: 8px 0; }
.online-dot { display: inline-block; width: 8px; height: 8px; background: #18d418; border-radius: 50%; margin-left: 5px; }
</style>
</head>
<body>
<div class="header">
    <div class="logo">شات اليمن العربي</div>
    <div>متصل: <span id="onlineCount">0</span></div>
</div>

<div class="main">
    <div class="center">
        <!-- شاشة الدخول -->
        <div class="room-card" id="authScreen">
            <div class="room-header">
                <h2>شات اليمن</h2>
                <p>غرفة دردشة شباب وبنات اليمن</p>
            </div>
            <div class="login-box">
                <div class="form-group">
                    <input type="text" id="username" placeholder="الإسم المستعار">
                </div>
                <div class="gender-select">
                    <div class="gender-option selected" onclick="selectGender(1)">♂ ذكر</div>
                    <div class="gender-option" onclick="selectGender(2)">♀ أنثى</div>
                </div>
                <input type="hidden" id="selectedGender" value="1">
                <button class="btn" onclick="joinChat()">دخول</button>
            </div>
        </div>

        <!-- شاشة الدردشة -->
        <div class="room-card chat-container" id="chatContainer">
            <div class="room-header">
                <h3>الغرفة العامة</h3>
            </div>
            <div class="user-list">
                <strong>المتصلين:</strong>
                <ul id="onlineUsersList"></ul>
            </div>
            <div class="chat-messages" id="messagesArea"></div>
            <div class="chat-input-area">
                <input type="text" class="chat-input" id="messageInput" placeholder="اكتب رسالتك...">
                <button class="send-btn" onclick="sendMessage()">إرسال</button>
            </div>
        </div>
    </div>
</div>

<!-- ========== جزء التغيير: كود Socket.io الجديد ========== -->
<script src="/socket.io/socket.io.js"></script>
<script>
const socket = io();
let currentUser = '';
let currentGender = 1;

function selectGender(g) {
    currentGender = g;
    document.querySelectorAll('.gender-option').forEach(el => el.classList.remove('selected'));
    document.querySelectorAll('.gender-option')[g-1].classList.add('selected');
    document.getElementById('selectedGender').value = g;
}

function joinChat() {
    const username = document.getElementById('username').value.trim();
    if (!username) {
        alert('اكتب اسم مستعار');
        return;
    }
    currentUser = username;
    currentGender = parseInt(document.getElementById('selectedGender').value);
    
    // إرسال بيانات المستخدم للسيرفر
    socket.emit('user join', { username: currentUser, gender: currentGender });
    
    document.getElementById('authScreen').style.display = 'none';
    document.getElementById('chatContainer').style.display = 'block';
}

function sendMessage() {
    const input = document.getElementById('messageInput');
    const message = input.value.trim();
    if (!message) return;
    
    // إرسال الرسالة للسيرفر
    socket.emit('chat message', { message: message });
    input.value = '';
}

// استقبال الرسائل من السيرفر
socket.on('chat message', (msg) => {
    const messagesArea = document.getElementById('messagesArea');
    const isMine = msg.user === currentUser;
    const genderClass = msg.gender == 1 ? 'male' : 'female';
    
    const messageDiv = document.createElement('div');
    messageDiv.className = `message ${isMine ? 'mine' : 'other'}`;
    messageDiv.innerHTML = `
        <div class="message-sender ${genderClass}">${msg.user}</div>
        <div>${msg.message}</div>
        <div style="font-size: 12px; color: #999;">${msg.time}</div>
    `;
    messagesArea.appendChild(messageDiv);
    messagesArea.scrollTop = messagesArea.scrollHeight;
});

// استقبال رسائل النظام
socket.on('system message', (msg) => {
    const messagesArea = document.getElementById('messagesArea');
    const systemDiv = document.createElement('div');
    systemDiv.className = 'system-message';
    systemDiv.textContent = msg;
    messagesArea.appendChild(systemDiv);
});

// تحديث قائمة المتصلين
socket.on('user list', (users) => {
    document.getElementById('onlineCount').textContent = users.length;
    const userList = document.getElementById('onlineUsersList');
    userList.innerHTML = '';
    users.forEach(user => {
        const li = document.createElement('li');
        li.innerHTML = `<span class="online-dot"></span> ${user.username}`;
        userList.appendChild(li);
    });
});

// إرسال بالانتر
document.getElementById('messageInput').addEventListener('keypress', (e) => {
    if (e.key === 'Enter') sendMessage();
});
</script>
<!-- ========== نهاية جزء التغيير ========== -->
</body>
</html>
